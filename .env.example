# Email Agent - Environment Variables Template
#
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control!
#
# See docs/configuration.md for full configuration reference.

# =============================================================================
# Path to config file (YAML format)
# =============================================================================
# Default: config.yaml in the project root
EMAIL_AGENT_CONFIG=config.yaml

# =============================================================================
# Logging
# =============================================================================
# Set to 1 to enable DEBUG verbose logging.
# WARNING: Verbose logging may contain sensitive information.
# See docs/usage.md for details on what is logged.
EMAIL_AGENT_VERBOSE=

# =============================================================================
# Polling Interval (optional override)
# =============================================================================
# Override the polling interval from config.yaml (in seconds).
# This is optional - if not set, the value from config.yaml is used.
# EMAIL_AGENT_POLL_INTERVAL=60
